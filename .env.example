# Copy to .env and fill in values
# Never commit .env — only .env.example

# ═════════════════════════════════════════════════════════════════════════════
# Broker
# ═════════════════════════════════════════════════════════════════════════════
DATABASE_URL=postgres://iex:iex@localhost:5432/iex_cannes
REDIS_URL=redis://localhost:6379
PORT=3001
BROKER_URL=http://localhost:3001

# ═════════════════════════════════════════════════════════════════════════════
# Frontend (Vite)
# ═════════════════════════════════════════════════════════════════════════════
VITE_BROKER_URL=

# ═════════════════════════════════════════════════════════════════════════════
# Arc (Prize 1: Best Smart Contract on Arc with Advanced Stablecoin Logic)
# ═════════════════════════════════════════════════════════════════════════════
# 
# Arc is Circle's USDC-native L1 blockchain. This project implements:
# - Conditional escrow with dispute + automatic release
# - Programmable payroll/vesting in USDC
# - 10% platform fee split
# - Native USDC integration (USDC is also the gas token on Arc)
#
# Arc Testnet Configuration:
# - RPC: https://rpc.testnet.arc.network
# - Chain ID: 5042002
# - Explorer: https://testnet.arcscan.app
# - USDC: 0x3600000000000000000000000000000000000000 (native gas token)
# - Faucet: https://faucet.circle.com (request USDC + EURC test tokens)
#
# To deploy contracts:
#   export PRIVATE_KEY=0x...
#   pnpm --filter intelligence-exchange-cannes-contracts deploy:arc-testnet

ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_ESCROW_CONTRACT_ADDRESS=
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Private key for broker to submit transactions to Arc
# Can be same as deployer or separate attestor account
ARC_PRIVATE_KEY=
ARC_ATTESTOR_PRIVATE_KEY=

# ═════════════════════════════════════════════════════════════════════════════
# 0G Storage (dossier)
# ═════════════════════════════════════════════════════════════════════════════
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_CHAIN_ID=16602
ZERO_G_EXPLorer_BASE_URL=https://chainscan-galileo.0g.ai/tx/
ZERO_G_PRIVATE_KEY=   # <-- NEVER commit this

# ═════════════════════════════════════════════════════════════════════════════
# World ID (4.0) + Agent Kit
# ═════════════════════════════════════════════════════════════════════════════
WORLD_APP_ID=
WORLD_ACTION_ID=
WORLD_RP_ID=
WORLD_SIGNING_KEY=
WORLD_VERIFICATION_SECRET=
WORLD_ENVIRONMENT=staging
WORLD_ID_STRICT=false

# ═════════════════════════════════════════════════════════════════════════════
# Worldchain
# ═════════════════════════════════════════════════════════════════════════════
WORLDCHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public
WORLDCHAIN_CHAIN_ID=480
WORLDCHAIN_AGENTBOOK_CONTRACT_ADDRESS=0xA23aB2712eA7BBa896930544C7d6636a96b944dA

# Deployed contracts (update after deployment)
IEX_IDENTITY_GATE_ADDRESS=
IEX_AGENT_REGISTRY_ADDRESS=
IEX_ESCROW_ADDRESS=

# ═════════════════════════════════════════════════════════════════════════════
# Agent Kit Configuration
# ═════════════════════════════════════════════════════════════════════════════
AGENTKIT_ENABLED=true
AGENTKIT_ACCESS_MODE=free-trial
AGENTKIT_FREE_TRIAL_USES=3
AGENTKIT_STATEMENT=Verify your agent is backed by a real human

# ═════════════════════════════════════════════════════════════════════════════
# Prize 1 Submission Notes
# ═════════════════════════════════════════════════════════════════════════════
# 
# For ETHGlobal Cannes 2026 Prize 1 submission, ensure:
# 
# 1. AdvancedArcEscrow.sol is deployed to Arc testnet
# 2. All environment variables above are configured
# 3. Demo shows: fund → reserve → submit → review → approve → release
# 4. Video highlights:
#    - USDC as native gas token (no ETH needed!)
#    - Conditional escrow (funds locked until reviewer approval)
#    - Dispute mechanism with challenge window
#    - Automatic release after timeout
#    - Programmable vesting (linear or milestone-based)
#    - 10% platform fee split on every release
# 
# Deployed contract address should be logged in:
#   packages/intelligence-exchange-cannes-contracts/broadcast/
