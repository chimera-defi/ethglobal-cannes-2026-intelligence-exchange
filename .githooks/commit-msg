#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?commit message file is required}"

# Skip merge commits generated by git.
if git rev-parse -q --verify MERGE_HEAD >/dev/null 2>&1; then
  exit 0
fi

subject="$(sed -n '1p' "${msg_file}")"

if [[ ! "${subject}" =~ \[Agent:[[:space:]][^]]+\]$ ]]; then
  echo "ERROR: Commit subject must end with [Agent: <MODEL NAME>]"
  echo "Example: feat(scope): summary [Agent: GPT-5 Codex]"
  exit 1
fi

if ! grep -Eq '^Co-authored-by:[[:space:]]+Chimera <chimera_defi@protonmail\.com>$' "${msg_file}"; then
  echo "ERROR: Commit message must include trailer:"
  echo "Co-authored-by: Chimera <chimera_defi@protonmail.com>"
  exit 1
fi
