{
  "name": "intelligence-exchange-cannes-broker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "test": "bun test",
    "test:acceptance": "bun test src/__tests__/acceptance",
    "seed": "bun run src/scripts/seed.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.3.0",
    "@hono/node-server": "^1.11.1",
    "@hono/zod-validator": "^0.2.2",
    "drizzle-orm": "^0.30.10",
    "postgres": "^3.4.4",
    "bullmq": "^5.7.0",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "viem": "^2.11.0",
    "intelligence-exchange-cannes-shared": "workspace:*",
    "intelligence-exchange-cannes-fixtures": "workspace:*"
  },
  "devDependencies": {
    "drizzle-kit": "^0.21.2",
    "typescript": "^5.4.5",
    "bun-types": "latest"
  }
}
