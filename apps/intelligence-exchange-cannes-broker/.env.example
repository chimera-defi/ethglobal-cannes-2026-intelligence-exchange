# Railway Production Environment
# Copy this to .env and fill in your values

# ═════════════════════════════════════════════════════════════════════════════
# Database (Railway provides these automatically)
# ═════════════════════════════════════════════════════════════════════════════
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# ═════════════════════════════════════════════════════════════════════════════
# Server
# ═════════════════════════════════════════════════════════════════════════════
PORT=3001
BROKER_URL=https://your-app.up.railway.app

# ═════════════════════════════════════════════════════════════════════════════
# Arc (Prize 1) - Get from Circle Faucet + Deploy Contracts
# ═════════════════════════════════════════════════════════════════════════════
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_ESCROW_CONTRACT_ADDRESS=0x...
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_PRIVATE_KEY=0x...
ARC_ATTESTOR_PRIVATE_KEY=0x...

# ═════════════════════════════════════════════════════════════════════════════
# World Agent Kit & World ID (Prizes 2 & 3)
# Get from: https://developer.worldcoin.org
# ═════════════════════════════════════════════════════════════════════════════
WORLD_APP_ID=app_...
WORLD_ACTION_ID=...
WORLD_RP_ID=...
WORLD_SIGNING_KEY=...
WORLD_VERIFICATION_SECRET=...
WORLD_ENVIRONMENT=staging
WORLD_ID_STRICT=false

# ═════════════════════════════════════════════════════════════════════════════
# Worldchain
# ═════════════════════════════════════════════════════════════════════════════
WORLDCHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public
WORLDCHAIN_CHAIN_ID=480
WORLDCHAIN_AGENTBOOK_CONTRACT_ADDRESS=0xA23aB2712eA7BBa896930544C7d6636a96b944dA
IEX_IDENTITY_GATE_ADDRESS=0x...
IEX_AGENT_REGISTRY_ADDRESS=0x...
IEX_ESCROW_ADDRESS=0x...

# ═════════════════════════════════════════════════════════════════════════════
# 0G (Prize 4) - Optional for demo
# ═════════════════════════════════════════════════════════════════════════════
ZERO_G_RPC_URL=
ZERO_G_INDEXER_RPC=
ZERO_G_CHAIN_ID=
ZERO_G_EXPLORER_BASE_URL=
ZERO_G_PRIVATE_KEY=

# ═════════════════════════════════════════════════════════════════════════════
# Agent Kit
# ═════════════════════════════════════════════════════════════════════════════
AGENTKIT_ENABLED=true
AGENTKIT_ACCESS_MODE=free-trial
AGENTKIT_FREE_TRIAL_USES=100
AGENTKIT_STATEMENT=Verify your agent is backed by a real human
