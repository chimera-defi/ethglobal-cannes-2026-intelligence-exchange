# Broker Environment Example
# Copy to .env and fill in values

DATABASE_URL=postgres://iex:iex@localhost:5432/iex_cannes
REDIS_URL=redis://localhost:6379
PORT=3001
BROKER_URL=http://localhost:3001

# CORS: comma-separated list of allowed origins (required in production)
# Set to your frontend domain(s) in production. Without this, credentials
# are disabled when NODE_ENV=production to prevent misconfiguration.
# Example: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:5173

# Attestation signing (required for on-chain attestations)
BROKER_ATTESTOR_PRIVATE_KEY=   # REQUIRED in prod — same key as ARC_ATTESTOR_PRIVATE_KEY; defaults to insecure Anvil dev key if unset

# Arc Testnet (OPTIONAL — only needed if ENABLE_ARC=true)
ENABLE_ARC=false   # Set to true to enable Arc chain integration
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_ESCROW_CONTRACT_ADDRESS=   # Optional: Arc escrow contract address
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_PRIVATE_KEY=   # Optional: broker wallet on Arc (set if ENABLE_ARC=true)
ARC_ATTESTOR_PRIVATE_KEY=   # Optional: same as BROKER_ATTESTOR_PRIVATE_KEY for Arc
ARC_WEBHOOK_SECRET=   # Optional: leave empty to skip Arc webhook signature verification

# Worldchain Sepolia (Staging)
WORLDCHAIN_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
WORLDCHAIN_CHAIN_ID=4801
WORLDCHAIN_AGENTBOOK_CONTRACT_ADDRESS=0xA23aB2712eA7BBa896930544C7d6636a96b944dA
IEX_IDENTITY_GATE_ADDRESS=0x0f917a7f6c41e5e86a0f3870baadf512a4742dd2
IEX_AGENT_REGISTRY_ADDRESS=0x88110316c5f96f3544cef90389e924c69eb8146d
IEX_ESCROW_ADDRESS=0x65e3d3c8032795c245f461439a01b8ad348bd3a1
WORK_RECEIPT_CONTRACT_ADDRESS=   # Optional — ERC-1155 on-chain mint; leave blank for off-chain-only mode

# World ID 4.0 (Staging)
WORLD_APP_ID=app_a3f0f85864f650c695989e62d3a39aca
WORLD_ACTION_ID=iex-worker-verify
WORLD_RP_ID=rp_abb9849b2199b040
WORLD_SIGNING_KEY=   # <-- Set via environment secret
WORLD_VERIFICATION_SECRET=   # <-- Set via environment secret
WORLD_ENVIRONMENT=staging
WORLD_ID_STRICT=false   # Set to true in production; false enables demo/dev mode without World ID verification

# Agent Kit
AGENTKIT_ENABLED=true
AGENTKIT_ACCESS_MODE=free-trial
AGENTKIT_FREE_TRIAL_USES=100
AGENTKIT_STATEMENT=Verify your agent is backed by a real human

# Tokenomics (all optional — defaults work for demo)
TOKENOMICS_ENABLED=true
TOKEN_BASE_PRICE_USD_PER_INTEL=1.0          # Curve floor price per INTEL token
TOKEN_TARGET_SUPPLY_INTEL=1000000           # Supply at which curve price doubles
TOKEN_PROTOCOL_FEE_BPS=1000                 # Protocol treasury fee (default 10%)
TOKEN_STAKER_YIELD_BPS=900                  # Staker yield fee (default 9%)
TOKEN_ADJUSTMENT_POWER=2                    # Curve steepness exponent
TOKEN_LIQUIDITY_DEPTH_USD=50000             # Liquidity depth for slippage calc
TOKEN_SLIPPAGE_BPS=50                       # Base slippage in basis points
