{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs", "pnpm"]
        },
        "install": {
          "cmds": [
            "corepack enable",
            "corepack pnpm install --frozen-lockfile"
          ]
        },
        "build": {
          "cmds": [
            "corepack pnpm --filter intelligence-exchange-cannes-broker build"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "bun run apps/intelligence-exchange-cannes-broker/dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}
