# Web App Environment
# Copy to .env.local and fill in values

# Broker API (defaults to relative path when deployed on same host)
# For self-hosted: http://YOUR_SERVER_IP/v1/cannes
VITE_BROKER_URL=http://168.119.15.122/v1/cannes

# Target chain — primary chains (Ethereum + Base)
VITE_CHAIN_ID=11155111          # Sepolia for demo; use 1 (mainnet) or 8453 (Base) for production
VITE_RPC_URL=https://rpc.sepolia.org

# Arc Testnet (OPTIONAL — future integration)
# VITE_ARC_CHAIN_ID=5042002
# VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# World Chain Sepolia (agent identity + AgentBook)
VITE_WORLDCHAIN_CHAIN_ID=4801
VITE_WORLDCHAIN_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
VITE_WORLDCHAIN_EXPLORER_URL=https://worldchain-sepolia.explorer.alchemy.com

# WalletConnect (optional — MetaMask injected works without this)
VITE_WALLETCONNECT_PROJECT_ID=

# INTEL Token + Staking + MintController contracts
# Get these from deployments/<chainId>.json after running Deploy.s.sol
# For local Anvil testing: bash packages/intelligence-exchange-cannes-contracts/scripts/demo-local-mint-staking.sh
# For Sepolia deploy: see docs/alliance-dao/REMAINING_GAPS.md → Track D Credential Checklist
VITE_INTEL_TOKEN_ADDRESS=
VITE_INTEL_STAKING_ADDRESS=
VITE_INTEL_MINT_CONTROLLER_ADDRESS=
