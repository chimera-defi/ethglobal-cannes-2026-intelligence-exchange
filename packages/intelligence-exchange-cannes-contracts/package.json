{
  "name": "intelligence-exchange-cannes-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bash ./scripts/run-forge.sh build",
    "fmt": "bash ./scripts/run-forge.sh fmt --check",
    "test": "bash ./scripts/run-forge.sh test -vvv",
    "deploy:local": "bash ./scripts/run-forge.sh script script/Deploy.s.sol:DeployCannes --rpc-url ${RPC_URL:-http://localhost:8545} --private-key ${PRIVATE_KEY:-0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80} --broadcast",
    "deploy:testnet": "bash ./scripts/run-forge.sh script script/Deploy.s.sol:DeployCannes --rpc-url $RPC_URL --private-key $PRIVATE_KEY --broadcast --verify"
  }
}
