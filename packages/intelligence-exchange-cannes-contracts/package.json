{
  "name": "intelligence-exchange-cannes-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "deploy:local": "forge script script/Deploy.s.sol --rpc-url http://localhost:8545 --broadcast",
    "deploy:testnet": "forge script script/Deploy.s.sol --rpc-url $RPC_URL --broadcast --verify",
    "worldchain:fork": "bash script/fork_worldchain.sh",
    "deploy:worldchain-fork": "WORLDCHAIN_DEPLOY_RPC_URL=${WORLDCHAIN_DEPLOY_RPC_URL:-http://127.0.0.1:8545} bash script/deploy_worldchain.sh",
    "deploy:worldchain": "bash script/deploy_worldchain.sh"
  }
}
