# Contracts Deployment Environment Example
# Copy to .env and fill in values

# Deployer private key (required)
PRIVATE_KEY=

# Optional address overrides (default to deployer if not set)
ATTESTOR_ADDRESS=
STAKER_YIELD_RECEIVER=
PLATFORM_WALLET=
DISPUTE_RESOLVER=
TEAM_WALLET=
GRANTS_MULTISIG=

# Timelock delay in seconds (default: 172800 = 48 hours)
# For testnets, set to 900 (15 min) or 7200 (2 hours)
TIMELOCK_DELAY=

# WorkReceipt1155 metadata base URI (default: https://api.iex.cannes/metadata/receipts/)
WORK_RECEIPT_BASE_URI=