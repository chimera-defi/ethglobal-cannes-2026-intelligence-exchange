{
  "name": "intelligence-exchange-cannes-2026",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "tooling:install": "bash scripts/tooling/ensure-foundry.sh",
    "dev:cannes": "pnpm --filter '*cannes*' --parallel run dev",
    "build": "pnpm tooling:install && pnpm --filter '*cannes*' run build",
    "test": "pnpm tooling:install && pnpm --filter '*cannes*' run test && pnpm test:infra-security",
    "test:infra-security": "bash tests/infra-security/verify-infra-hardening.sh",
    "test:infra-security:ci": "REQUIRE_DOCKER=1 bash tests/infra-security/verify-infra-hardening.sh",
    "test:acceptance": "pnpm --filter 'intelligence-exchange-cannes-broker' run test:acceptance",
    "contracts:validate": "pnpm tooling:install && pnpm --filter 'intelligence-exchange-cannes-contracts' run test",
    "seed:cannes": "pnpm --filter 'intelligence-exchange-cannes-broker' run seed",
    "typecheck": "pnpm --filter '*cannes*' run typecheck",
    "validate:all": "pnpm tooling:install && pnpm typecheck && pnpm build && pnpm test && pnpm test:acceptance && pnpm test:infra-security:ci"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
